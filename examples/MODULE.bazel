        "qtgraphicaleffects-everywhere-opensource-src-5.15.18.tar.xz": "dbefca590ef1d1f1c79c396f0f28f73cc16465c3a80803acc4a3ffa2f6d63225",
        "qtquickcontrols-everywhere-opensource-src-5.15.18.tar.xz": "78b05bfac92bef099209aa56fdf4ca4558172583752f6736450fc0368bde01df",
