module(name = "com_github_kklochkov_rules_qt_examples")

bazel_dep(name = "rules_qt", version = "2.0.0")
bazel_dep(name = "rules_cc", version = "0.1.1")
local_path_override(
    module_name = "rules_qt",
    path = "..",
)

http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")
http_files = use_repo_rule("//:http_files.bzl", "http_files")

qt = use_extension("@rules_qt//qt:extensions.bzl", "qt")

# Local Qt candidates with platform-conditional paths.
qt.local_repo(
    name = "qt5_local",
    paths = {
        "macos-arm64": "/opt/homebrew/opt/qt@5",
        "linux-x86_64": "/usr/lib/x86_64-linux-gnu/qt5",
    },
)

qt.local_repo(
    name = "qt6_local",
    paths = {
        "macos-arm64": "/opt/homebrew/opt/qt",
        "linux-x86_64": "/usr/lib/qt6",
    },
)

# Remote Qt candidates from source tarballs.
qt.remote_repo(
    name = "qt5_remote",
    base_url = "https://download.qt.io/archive/qt/5.15/5.15.18/submodules",
    configure_args = [
        "-opensource",
        "-confirm-license",
        "-release",
        "-shared",
        "-nomake",
        "examples",
        "-nomake",
        "tests",
    ],
    # @unsorted-dict-items
    # order matters
    modules = {
        "qtbase-everywhere-opensource-src-5.15.18.tar.xz": "7b632550ea1048fc10c741e46e2e3b093e5ca94dfa6209e9e0848800e247023b",
        "qtimageformats-everywhere-opensource-src-5.15.18.tar.xz": "bf86000a21a1280f7a8aaf12dd9a10e59e778169653b53c86ad8f346fb39c066",
