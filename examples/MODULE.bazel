        "qtquick3d-everywhere-opensource-src-5.15.18.tar.xz": "24743512942e882973abfc71f60e77c350b66d41cc8c9e315171cb84fb638e0c",
    },
    prefix = "qt-5.15.18",
)

qt.remote_repo(
    name = "qt6_remote",
    base_url = "https://download.qt.io/official_releases/qt/6.11/6.11.0/submodules",
    configure_args = [
        "-opensource",
        "-confirm-license",
        "-release",
        "-shared",
        "-nomake",
        "examples",
        "-nomake",
        "tests",
    ],
    # @unsorted-dict-items
    # order matters
    modules = {
        "qtbase-everywhere-src-6.11.0.tar.xz": "231ad85979864d914dc9568a1b71c91d6cf20d7b2021d059103bf0eb51cb755e",
        "qtimageformats-everywhere-src-6.11.0.tar.xz": "d3adb02ac5e2fe24068dbdaee0d7cc68cc3fa8553291c1bfce77c9fe8e940cc8",
        "qtsvg-everywhere-src-6.11.0.tar.xz": "dfa8d653be07087d9407ed4a4ebae847f8953e0b7abd829f089803ab652a30e6",
        "qtshadertools-everywhere-src-6.11.0.tar.xz": "e43cb1ae8809b2a858281ee269f98da59d0fc1bcf958ca5510c81f7ad3d2e14a",
        "qtdeclarative-everywhere-src-6.11.0.tar.xz": "4eece569431ddf8324e7d322fa27001916570b23df535f8fb28aba445eedfde9",
        "qtquicktimeline-everywhere-src-6.11.0.tar.xz": "06dbe1cc541431fa321023992ca4ccf83c76b25d07bbf516e0af887a38f32cd6",
