# Active SDK switch — change the repo value to switch:
#   qt5_local / qt6_local    — locally installed Qt (path auto-selected by platform)
#   qt5_remote / qt6_remote  — source-built Qt
qt.active_sdk(name = "qt", repo = "qt6_local")
use_repo(qt, "qt")

